{
  "name": "gh-contrib-stats",
  "version": "0.1.0",
  "description": "Generate a static SVG contribution card with the unique filed-and-fixed metric",
  "type": "module",
  "bin": {
    "gh-contrib-stats": "./dist/index.js"
  },
  "files": [
    "dist",
    "action.yml"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["github", "stats", "svg", "contribution", "profile", "readme"],
  "author": "Nexory",
  "license": "MIT",
  "dependencies": {
    "@octokit/graphql": "^8.1.1",
    "@octokit/rest": "^21.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.21.5",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
